{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "python -m venv /app/.venv",
        "pip install --upgrade pip",
        "pip install requests beautifulsoup4 playwright",
        "python -m playwright install chromium"
      ]
    }
  },
  "deploy": {
    "startCommand": "python app.py"
  }
}
